---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';

import { mediumarticles } from '../../data/mediumArticles';

interface PostData {
  slug: string;
  title?: string;
  date?: string;
  redirect?: string;
  description?: string;
  [key: string]: any;
}

const posts = import.meta.glob('../../posts/**/*.mdx', { eager: true });
const postData: PostData[] = Object.entries(posts).map(([file, post]: [string, any]): PostData => {
  const slug = file.replace('../../posts/', '').replace(/\.mdx$/, '');
  
  return {
    slug,
    ...post.frontmatter
  };
});

const mediumPosts: PostData[] = mediumarticles.map(article => ({
  slug: `m/${article.slug}`,
  title: article.title,
  description: article.description || '',
  date: article.date,
  redirect: article.redirect,
    tags: article.tags
}));

const allPosts = [...postData, ...mediumPosts];

const sortedPosts = allPosts.sort((a, b) => {
  const dateA = new Date(a.date || '1970-01-01').getTime();
  const dateB = new Date(b.date || '1970-01-01').getTime();
  return dateB - dateA;
});
---
<Layout title="All Posts" wide={true}>
  <div class="mb-8">
    <div class="p-4 sm:p-6">
      <div class="flex flex-col sm:flex-row sm:items-start gap-4">
        <img 
          src="/gradientlogs.webp" 
          alt="GradientLogs logo" 
          class="w-10 h-10 rounded-lg"
        />
        <div class="flex-1">
          <h2 class="text-lg font-medium mb-2">Subscribe to GradientLogs</h2>
          <p class="text-gruvbox-light/70 dark:text-gruvbox-dark/70 mb-4 text-sm sm:text-base">Deep dives into ML architectures and thoughts on culture, art, and everything in between.</p>
          <div class="flex justify-start">
            <a 
              href="https://himanshustwts.substack.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gruvbox-light-accent dark:text-gruvbox-dark-accent border border-current rounded-lg hover:bg-gruvbox-light-accent/5 dark:hover:bg-gruvbox-dark-accent/5 transition-colors"
            >
              Subscribe to Newsletter
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
  </div>

  <div class="mb-6">
    <input 
      type="text" 
      id="searchInput" 
      placeholder="Search posts by title, description, or tags..." 
      class="w-full p-3 border dark:border-gruvbox-dark-accent border-gruvbox-light-accent dark:bg-gruvbox-dark-accent/10 bg-gruvbox-light-accent/20 focus:outline-none focus:ring-2 dark:focus:ring-gruvbox-dark-accent focus:ring-gruvbox-light-accent"
    />
  </div>
  
  
  <div id="postsContainer" class="posts-list flex flex-col w-full">
    {sortedPosts.map((post) => (
      <a href={ post.tags?.includes("medium") ? `/${post.slug}` : `/posts/${post.slug}`} class="post-item w-full dark:hover:text-gruvbox-dark-bg hover:text-gruvbox-light-bg dark:hover:bg-gruvbox-dark-accent hover:bg-gruvbox-light-accent py-4 px-4 border-b border-gruvbox-light-bg-lighter/30 dark:border-gruvbox-dark-bg-lighter/30" data-title={post.title} data-description={post.description} data-tags={post.tags?.join(' ')}>
        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <h2 class="text-base">{post.title}</h2>
          <time class="text-sm text-gruvbox-light/50 dark:text-gruvbox-dark/50 shrink-0">{post.date}</time>
        </div>
        {post.description && <p class="mt-1 text-sm text-gruvbox-light/60 dark:text-gruvbox-dark/60">{post.description}</p>}
      </a>
    ))}
  </div>

  <script>
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const postsContainer = document.getElementById('postsContainer') as HTMLElement;
    const allPosts = Array.from(postsContainer.querySelectorAll('.post-item')) as HTMLElement[];
    
    searchInput.addEventListener('input', () => {
      const searchTerm = searchInput.value.toLowerCase().trim();
      
      allPosts.forEach(post => {
        const title = post.getAttribute('data-title')?.toLowerCase() || '';
        const description = post.getAttribute('data-description')?.toLowerCase() || '';
        const tags = post.getAttribute('data-tags')?.toLowerCase() || '';
        
        const matches = !searchTerm || 
                        title.includes(searchTerm) || 
                        description.includes(searchTerm) || 
                        tags.includes(searchTerm);
        
        post.style.display = matches ? 'block' : 'none';
      });
    });
  </script>
</Layout>