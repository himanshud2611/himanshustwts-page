---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { mediumarticles } from '../../data/mediumArticles';

const { slug } = Astro.params;

export async function getStaticPaths() {
  return mediumarticles.map((post) => ({
    params: { slug: post.slug },
  }));
}

const matchedPost = mediumarticles.find(post => post.slug === slug);

// Redirect if found
if (matchedPost && matchedPost.redirect) {
  return Astro.redirect(matchedPost.redirect);
}
---

<Layout title="Post not found">
  <div class="space-y-4">
    <h1 class="text-3xl font-bold">Post not found</h1>
    <p>
      This Medium redirect does not exist anymore. Head back to <a
        href="/posts"
        class="text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium"
        >all posts</a
      >.
    </p>
  </div>
</Layout>