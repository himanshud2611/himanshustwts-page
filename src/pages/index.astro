---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import ExternalLinkIcon from "../components/ExternalLinkIcon.astro";
import Newsletter from "../components/Newsletter.astro";

const title = "Himanshu";

const experience = [
    {
        role: "Research x Product",
        company: "Upsurge",
        companyUrl: "https://upsurge.io",
        iconPath: "/upsurge-logo.jpg",
        date: "Feb 2025 - Feb 2026",
        description:
            "Founding Team: Bluebrain, Bhindi AI, Anannas AI, Mogra, Upsurge Grants",
    },
    {
        role: "ML Engineer",
        company: "SproutsAI",
        companyUrl: "https://www.sproutsai.com",
        iconPath: "/sproutsai.webp",
        date: "Oct 2024 - Feb 2025",
        description:
            "Built end-to-end autonomous agentic AI systems for hiring automation, data enrichment, and document processing.",
    },
    {
        role: "Research Intern",
        company: "IITB Trust Lab",
        companyUrl: "https://trustlab.iitb.ac.in/",
        iconPath: "/trustlab.webp",
        date: "Jun 2024 - Aug 2024",
        description:
            "Collaborated on 'Domain Knowledge based Q/A for LLMs', optimizing and fine-tuning LLMs for open-ended medical question answering.",
    },
];
---

<Layout title={title}>
    <div class="space-y-16 max-w-3xl">
        {/* Hero Section */}
        <div class="space-y-6">
            <div>
                <div class="flex items-center gap-4 mb-2">
                    <img 
                        src="https://unavatar.io/twitter/himanshustwts" 
                        alt="Himanshu's profile picture" 
                        class="w-12 h-12 rounded-full"
                        onerror="this.src='https://api.dicebear.com/7.x/avataaars/svg?seed=himanshu'; this.onerror=null;"
                    />
                    <h1 class="text-4xl font-medium">himanshu</h1>
                </div>
                <div class="flex items-center gap-4 mt-1">
                    <a
                        href="/posts"
                        class="inline-flex items-center text-sm text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium"
                    >
                        Writings
                        <ExternalLinkIcon />
                    </a>
                    <a
                        href="/readings"
                        class="inline-flex items-center text-sm text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium"
                    >
                        Readings
                        <ExternalLinkIcon />
                    </a>
                </div>
            </div>

            <p
                class="text-lg max-w-[480px] leading-relaxed text-gruvbox-light/90 dark:text-gruvbox-dark/90"
            >
                I am Co-founder of <a href="https://physera.ai" target="_blank" rel="noopener noreferrer" class="text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium">Physera<ExternalLinkIcon /></a>. We are building systems that (perceive + reason + decide) as humans do, under the constraints humans face. Essentially, we are working at the intersection of model efficiency and behavioural simulations while building environments that are multimodal.
                <br />
                I host podcasts with interesting people in AI and Tech at <a href="https://www.groundzeroai.in/" target="_blank" rel="noopener noreferrer" class="text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium">Ground Zero<ExternalLinkIcon /></a>.
                <br />
                <br />
                my <a href="https://x.com/himanshustwts/highlights" target="_blank" rel="noopener noreferrer" class="text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium">X highlights<ExternalLinkIcon /></a> might be insightful for you.
            </p>

            <div class="flex flex-wrap gap-6 text-sm">
                <a
                    href="https://twitter.com/himanshustwts"
                    class="inline-flex items-center text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <svg class="w-4 h-4 mr-2" viewBox="0 0 24 24">
                        <path
                            fill="currentColor"
                            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                        ></path>
                    </svg>
                    <span>@himanshustwts</span>
                    <ExternalLinkIcon />
                </a>
                <a
                    href="https://x.com/groundzero_twt"
                    class="inline-flex items-center text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <svg class="w-4 h-4 mr-2" viewBox="0 0 24 24">
                        <path
                            fill="currentColor"
                            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                        ></path>
                    </svg>
                    <span>Ground Zero</span>
                    <ExternalLinkIcon />
                </a>
                <a
                    href="https://www.linkedin.com/in/himanshud2611/"
                    class="inline-flex items-center text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <svg class="w-4 h-4 mr-2" viewBox="0 0 24 24">
                        <path
                            fill="currentColor"
                            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                        ></path>
                    </svg>
                    <span>LinkedIn</span>
                    <ExternalLinkIcon />
                </a>
            </div>
        </div>

        {/* Past Life Accordion */}
        <div class="space-y-6">
            <button
                    id="previous-life-toggle"
                    class="flex items-center gap-1 text-left font-medium hover:opacity-80 transition-opacity cursor-pointer decoration-dotted underline"
                >
                    <span>Past Life</span>
                    <svg
                        id="previous-life-arrow"
                        class="inline-block w-3 h-3 ml-0.5 mb-0.5 transition-transform duration-200 text-gruvbox-light-accent dark:text-gruvbox-dark-accent"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                        />
                    </svg>
                </button>


            <div
                id="previous-life-content"
                    class="hidden overflow-hidden transition-all duration-300"
                >
                    <div
                        class="relative border-l border-gruvbox-light/30 dark:border-gruvbox-dark/30 ml-2 pt-4"
                    >
                        {
                            experience.map((exp, index) => (
                                <div
                                    class={`relative ml-6 ${index < experience.length - 1 ? "mb-8" : ""}`}
                                >
                                    <div class="absolute w-3 h-[1px] bg-gruvbox-light/30 dark:bg-gruvbox-dark/30 -left-6 top-[0.8rem]" />
                                    <div class="space-y-1">
                                        <div class="flex items-center gap-4">
                                            {exp.iconPath && (
                                                <img
                                                    src={exp.iconPath}
                                                    alt={`${exp.company} logo`}
                                                    class="w-10 h-10 object-contain flex-shrink-0 rounded-lg"
                                                    loading="lazy"
                                                />
                                            )}
                                            <div class="flex flex-col justify-center">
                                                <h3 class="font-medium">
                                                    {exp.role} •{" "}
                                                    {exp.companyUrl ? (
                                                        <a
                                                            href={exp.companyUrl}
                                                            target="_blank"
                                                            rel="noopener noreferrer"
                                                            class="text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity"
                                                        >
                                                            {exp.company}
                                                            <ExternalLinkIcon />
                                                        </a>
                                                    ) : (
                                                        exp.company
                                                    )}
                                                </h3>
                                                <p class="text-sm text-gruvbox-light/70 dark:text-gruvbox-dark/70">
                                                    {exp.date}
                                                </p>
                                            </div>
                                        </div>
                                        <p class="mt-3">
                                            {exp.description}
                                        </p>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>


            <script>
                    const toggle = document.getElementById('previous-life-toggle');
                    const content = document.getElementById('previous-life-content');
                    const arrow = document.getElementById('previous-life-arrow');

                    toggle?.addEventListener('click', () => {
                        content?.classList.toggle('hidden');
                    });
                </script>
            </div>
        </div>

        {/* Newsletter Section */}
        <Section title="stay in the loop" class="mt-12">
            <Newsletter />
        </Section>

        <p class="mt-10 text-lg leading-relaxed text-gruvbox-light/90 dark:text-gruvbox-dark/90">
            Send an email: <a
                href="mailto:himanshu@physera.ai"
                class="text-gruvbox-light-accent dark:text-gruvbox-dark-accent hover:opacity-80 transition-opacity font-medium"
                >himanshu@physera.ai<ExternalLinkIcon /></a
            >
        </p>

    </div>
</Layout>
